{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "webhook_url": {
      "type": "string",
      "description": "DingTalk custom robot webhook URL with access_token."
    },
    "webhookUrl": {
      "type": "string",
      "description": "Alias for webhook_url."
    },
    "webhook": {
      "type": "string",
      "description": "Alias for webhook_url."
    },
    "url": {
      "type": "string",
      "description": "Alias for webhook_url."
    },
    "secret": {
      "type": "string",
      "description": "DingTalk signing secret. Prefer secret.secret for new instances."
    },
    "dingding_secret": {
      "type": "string",
      "description": "Legacy alias for secret. Prefer secret.dingding_secret for new instances."
    },
    "timeoutMs": {
      "type": "integer",
      "minimum": 1,
      "default": 5000,
      "description": "HTTP timeout in milliseconds."
    },
    "timeout_ms": {
      "type": "integer",
      "minimum": 1,
      "description": "Legacy alias for timeoutMs."
    }
  }
}
