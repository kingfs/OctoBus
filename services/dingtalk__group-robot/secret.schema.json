  "type": "object",
  "additionalProperties": false,
  "properties": {
    "webhook_url": {
      "type": "string",
      "description": "DingTalk custom robot webhook URL with access_token."
    },
    "webhook": {
      "type": "string",
      "description": "Deprecated alias for webhook_url."
    },
    "webhookUrl": {
      "type": "string",
      "description": "Deprecated alias for webhook_url."
    },
    "url": {
      "type": "string",
      "description": "Deprecated alias for webhook_url."
    },
    "secret": {
      "type": "string",
