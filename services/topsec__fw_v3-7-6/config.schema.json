{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "host": {
      "type": "string",
      "description": "TopSec FW V3.7.6 WebUI base URL."
    },
    "baseUrl": {
      "type": "string",
      "description": "Alias for host."
    },
    "restBaseUrl": {
      "type": "string",
      "description": "Alias for host."
    },
    "user": {
      "type": "string",
      "description": "Optional default login username."
    },
    "username": {
      "type": "string",
      "description": "Alias for user."
    },
    "aesKey": {
      "type": "string",
      "description": "AES key as hex, base64, or UTF-8 text."
    },
    "aesIv": {
      "type": "string",
      "description": "AES IV as hex, base64, or UTF-8 text."
    },
    "memo": {
      "type": "string",
      "default": "Block IP",
      "description": "Default memo for added blacklist entries."
    },
    "timeoutMs": {
      "type": "integer",
      "minimum": 1,
      "default": 5000,
      "description": "HTTP timeout in milliseconds."
    },
    "skipTlsVerify": {
      "type": "boolean",
      "default": false,
      "description": "Skip TLS certificate verification for private deployments."
    },
    "tlsInsecureSkipVerify": {
      "type": "boolean",
      "default": false,
      "description": "Legacy alias for skipTlsVerify."
    },
    "allow_http": {
      "type": "boolean",
      "default": false,
      "description": "Allow plain HTTP for local mocks or lab environments."
    },
    "allowHttp": {
      "type": "boolean",
      "default": false,
      "description": "Alias for allow_http."
    },
    "headers": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      },
      "description": "Optional additional HTTP headers."
    }
  }
}
