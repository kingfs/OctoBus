{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "token": {
      "type": "string",
      "description": "Fortinet REST API token."
    },
    "accessToken": {
      "type": "string",
      "description": "Alias for token."
