{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "email": {
      "type": "string",
      "description": "FOFA account email."
    },
    "fofa_email": {
      "type": "string",
      "description": "Alias for email."
    },
    "key": {
      "type": "string",
      "description": "FOFA API key."
    },
    "api_key": {
      "type": "string",
      "description": "Alias for key."
    },
    "fofa_api_key": {
      "type": "string",
      "description": "Alias for key."
    }
  }
}