{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "host": {
      "type": "string",
      "description": "Tencent TSec API gateway URL, including protocol and API path."
    },
    "baseUrl": {
      "type": "string",
      "description": "Alias for host."
    },
    "uuid": {
      "type": "string",
      "description": "Caller business UUID required by Tencent TSec."
    },
    "timeoutMs": {
      "type": "integer",
      "minimum": 1,
      "default": 5000,
      "description": "HTTP timeout in milliseconds."
    },
    "skipTlsVerify": {
      "type": "boolean",
      "default": false,
      "description": "Skip TLS certificate verification for private deployments."
    },
    "tlsInsecureSkipVerify": {
      "type": "boolean",
      "default": false,
      "description": "Legacy alias for skipTlsVerify."
    },
    "insecureSkipVerify": {
      "type": "boolean",
      "default": false,
      "description": "Alias for skipTlsVerify."
    },
    "headers": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      },
      "description": "Optional additional HTTP headers. Core JSON and trace headers are set by the service."
    }
  }
}
