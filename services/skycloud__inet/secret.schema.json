{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "username": {
      "type": "string",
      "description": "SKYCloud username allowed to create tickets."
    },
    "user": {
      "type": "string",
      "description": "Legacy alias for username."
    },
    "password": {
      "type": "string",
      "description": "SKYCloud password corresponding to username."
    }
  }
}
