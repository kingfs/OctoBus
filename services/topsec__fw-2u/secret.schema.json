{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "username",
    "password"
  ],
  "properties": {
    "username": {
      "type": "string",
      "minLength": 1,
      "description": "TopSec WebUI login username."
    },
    "password": {
      "type": "string",
      "minLength": 1,
      "description": "TopSec WebUI login password."
    }
  }
}
