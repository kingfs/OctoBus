{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "accessKeyId": {
      "type": "string",
      "description": "DBAudit OpenAPI access key ID."
    },
    "access_key_id": {
      "type": "string",
      "description": "Alias for accessKeyId."
    },
    "accessKey": {
      "type": "string",
      "description": "Alias for accessKeyId."
    },
    "access_key": {
      "type": "string",
      "description": "Alias for accessKeyId."
    },
    "accessKeySecret": {
      "type": "string",
      "description": "DBAudit OpenAPI access key secret used to compute accessSign."
    },
    "access_key_secret": {
      "type": "string",
      "description": "Alias for accessKeySecret."
    },
    "accessSecret": {
      "type": "string",
      "description": "Alias for accessKeySecret."
    },
    "access_secret": {
      "type": "string",
      "description": "Alias for accessKeySecret."
    }
  }
}
