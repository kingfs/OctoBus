{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "baseUrl": {
      "type": "string",
      "description": "Full Wangsu OpenAPI POST endpoint URL."
    },
    "restBaseUrl": {
      "type": "string",
      "description": "Alias for baseUrl."
    },
    "url": {
      "type": "string",
      "description": "Alias for baseUrl."
    },
    "user": {
      "type": "string",
      "description": "Wangsu account/user name."
    },
    "labelCode": {
      "type": "string",
      "description": "Default Wangsu label code."
    },
    "label_code": {
      "type": "string",
      "description": "Alias for labelCode."
    },
    "wangsu_tag": {
      "type": "string",
      "description": "Legacy alias for labelCode."
    },
    "wangsuTag": {
      "type": "string",
      "description": "Legacy alias for labelCode."
    },
    "defaultForbidMinutes": {
      "type": "integer",
      "minimum": 1,
      "default": 60,
      "description": "Default forbid duration in minutes."
    },
    "default_forbid_minutes": {
      "type": "integer",
      "minimum": 1,
      "description": "Alias for defaultForbidMinutes."
    },
    "timeoutMs": {
      "type": "integer",
      "minimum": 1,
      "default": 5000,
      "description": "HTTP timeout in milliseconds."
    },
    "timeout_ms": {
      "type": "integer",
      "minimum": 1,
      "description": "Alias for timeoutMs."
    },
    "timeout": {
      "type": "integer",
      "minimum": 1,
      "description": "Alias for timeoutMs."
    },
    "overrideDateHeader": {
      "type": "string",
      "description": "Test-only fixed Date header."
    },
    "dateHeader": {
      "type": "string",
      "description": "Alias for overrideDateHeader."
    },
    "skipTlsVerify": {
      "type": "boolean",
      "default": false,
      "description": "Skip TLS certificate verification for private deployments."
    },
    "tlsInsecureSkipVerify": {
      "type": "boolean",
      "default": false,
      "description": "Alias for skipTlsVerify."
    },
    "tls_skip_verify": {
      "type": "boolean",
      "default": false,
      "description": "Alias for skipTlsVerify."
    },
    "headers": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      },
      "description": "Optional additional HTTP headers."
    }
  }
}
