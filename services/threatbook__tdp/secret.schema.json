{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "api_key": {
      "type": "string",
      "description": "ThreatBook TDP API key."
    },
    "apiKey": {
      "type": "string",
      "description": "Alias for api_key."
    },
    "secret": {
      "type": "string",
      "description": "ThreatBook TDP HMAC-SHA256 secret."
    },
    "Secret": {
      "type": "string",
      "description": "Legacy alias for secret."
    }
  }
}
