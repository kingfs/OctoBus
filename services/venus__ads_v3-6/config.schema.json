{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "baseUrl": {
      "type": "string",
      "description": "Venus ADS V3.6 REST base URL, including the /cnddos prefix when required."
    },
    "restBaseUrl": {
      "type": "string",
      "description": "Alias for baseUrl."
    },
    "host": {
      "type": "string",
      "description": "Alias for baseUrl."
    },
    "username": {
      "type": "string",
      "description": "Optional default login username."
    },
    "user": {
      "type": "string",
      "description": "Alias for username."
    },
    "remark": {
      "type": "string",
      "default": "万象IP封禁",
      "description": "Remark written to Venus blacklist entries."
    },
    "ipdirection": {
      "type": "integer",
      "default": 1,
      "description": "Venus ipdirection value for blacklist entries."
    },
    "ipstate": {
      "type": "integer",
      "default": 100,
      "description": "Venus ipstate value for blacklist entries."
    },
    "listtype": {
      "type": "string",
      "default": "100",
      "description": "Venus listtype value for blacklist operations."
    },
    "sessionTimeoutSeconds": {
      "type": "integer",
      "minimum": 1,
      "default": 1800,
      "description": "Login session timeout sent to Venus ADS."
    },
    "timeoutMs": {
      "type": "integer",
      "minimum": 1,
      "default": 8000,
      "description": "HTTP timeout in milliseconds."
    },
    "skipTlsVerify": {
      "type": "boolean",
      "default": false,
      "description": "Skip TLS certificate verification for private deployments."
    },
    "tlsInsecureSkipVerify": {
      "type": "boolean",
      "default": false,
      "description": "Legacy alias for skipTlsVerify."
    },
    "headers": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      },
      "description": "Optional additional HTTP headers."
    }
  }
}
