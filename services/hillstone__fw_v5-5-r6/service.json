{
  "schema": "chaitin.octobus.service.v1",
  "name": "hillstone-fw-v5-5-r6",
  "displayName": "Hillstone FW V5.5R6",
  "description": "OctoBus package for Hillstone Firewall V5.5R6 login and address group APIs.",
  "runtime": {
    "mode": "long-running"
  },
  "proto": {
    "roots": [
      "proto"
    ],
    "files": [
      "proto/hillstone_fw_v5_5_r6.proto"
    ]
  },
  "configSchema": "config.schema.json",
  "secretSchema": "secret.schema.json",
  "sdk": {
    "cli": {
      "commands": {
        "HILLSTONE_FW_V55R6.HILLSTONE_FW_V55R6/Login": {
          "name": "login",
          "description": "Login to Hillstone FW V5.5R6."
        },
        "HILLSTONE_FW_V55R6.HILLSTONE_FW_V55R6/CreateAddrGroup": {
          "name": "create-addr-group",
          "description": "Create Hillstone address groups."
        },
        "HILLSTONE_FW_V55R6.HILLSTONE_FW_V55R6/UpdateAddrGroup": {
          "name": "update-addr-group",
          "description": "Update Hillstone address groups."
        },
        "HILLSTONE_FW_V55R6.HILLSTONE_FW_V55R6/QueryAddrGroup": {
          "name": "query-addr-group",
          "description": "Query a Hillstone address group by name."
        }
      }
    }
  }
}
