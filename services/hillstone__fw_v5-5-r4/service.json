{
  "schema": "chaitin.octobus.service.v1",
  "name": "hillstone-fw-v5-5-r4",
  "displayName": "Hillstone FW V5.5R4",
  "description": "OctoBus package for Hillstone Firewall V5.5R4 login and address-book APIs.",
  "runtime": {
    "mode": "long-running"
  },
  "proto": {
    "roots": [
      "proto"
    ],
    "files": [
      "proto/hillstone_fw_v5_5_r4.proto"
    ]
  },
  "configSchema": "config.schema.json",
  "secretSchema": "secret.schema.json",
  "sdk": {
    "cli": {
      "commands": {
        "HILLSTONE_FW_V55R4.HILLSTONE_FW_V55R4/Login": {
          "name": "login",
          "description": "Login to Hillstone FW V5.5R4."
        },
        "HILLSTONE_FW_V55R4.HILLSTONE_FW_V55R4/CreateAddressGroup": {
          "name": "create-address-group",
          "description": "Create Hillstone address groups."
        },
        "HILLSTONE_FW_V55R4.HILLSTONE_FW_V55R4/UpdateAddressGroup": {
          "name": "update-address-group",
          "description": "Update Hillstone address groups."
        },
        "HILLSTONE_FW_V55R4.HILLSTONE_FW_V55R4/QueryAddressGroup": {
          "name": "query-address-group",
          "description": "Query a Hillstone address group by name."
        }
      }
    }
  }
}
