{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "password": {
      "type": "string",
      "description": "Hillstone login password. This service passes it through unchanged."
    },
    "user_name": {
      "type": "string",
      "description": "Hillstone login username."
    },
    "userName": {
      "type": "string",
      "description": "Alias for user_name."
    }
  }
}
