{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "base_url": {
      "type": "string",
      "description": "ThreatBook OneSIG base URL. HTTPS is required unless allow_http is true."
    },
    "baseUrl": {
      "type": "string",
      "description": "Alias for base_url."
    },
    "allow_http": {
      "type": "boolean",
      "default": false,
      "description": "Allow http:// base URLs for local mock testing."
    },
    "allowInsecureHttp": {
      "type": "boolean",
      "default": false,
      "description": "Alias for allow_http."
    },
    "timeoutMs": {
      "type": "integer",
      "minimum": 1,
      "default": 1500,
      "description": "HTTP timeout in milliseconds."
    },
    "skipTlsVerify": {
      "type": "boolean",
      "default": false,
      "description": "Skip TLS certificate verification for private deployments."
    },
    "tlsInsecureSkipVerify": {
      "type": "boolean",
      "default": false,
      "description": "Legacy alias for skipTlsVerify."
    },
    "signature_mode": {
      "type": "string",
      "enum": [
        "apiKey+timestamp",
        "timestamp+apiKey",
        "apiKey",
        "timestamp"
      ],
      "default": "apiKey+timestamp",
      "description": "String used for HMAC-SHA1 signing."
    },
    "signatureMode": {
      "type": "string",
      "description": "Alias for signature_mode."
    },
    "timestamp_precision": {
      "type": "string",
      "enum": [
        "seconds",
        "milliseconds"
      ],
      "default": "seconds",
      "description": "Timestamp query parameter precision."
    },
    "timestampPrecision": {
      "type": "string",
      "description": "Alias for timestamp_precision."
    },
    "encode_sign": {
      "type": "boolean",
      "default": true,
      "description": "URL encode the Base64 HMAC signature."
    },
    "encodeSign": {
      "type": "boolean",
      "description": "Alias for encode_sign."
    },
    "headers": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      },
      "description": "Optional additional HTTP headers."
    }
  }
}
