{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "password": {
      "type": "string",
      "description": "Plaintext login password; the service sends its SHA-256 digest."
    },
    "password_clear": {
      "type": "string",
      "description": "Alias for password."
    },
    "password_sha256": {
      "type": "string",
      "description": "Precomputed SHA-256 password digest."
    },
    "passwordSha256": {
      "type": "string",
      "description": "Alias for password_sha256."
    }
  }
}
