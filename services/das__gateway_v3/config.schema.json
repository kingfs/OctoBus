{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "host": {
      "type": "string",
      "description": "DAS Gateway V3 management base URL, for example https://10.2.28.106:9090."
    },
    "endpoint": {
      "type": "string",
      "description": "Alias for host."
    },
    "baseUrl": {
      "type": "string",
      "description": "Alias for host."
    },
    "base_url": {
      "type": "string",
      "description": "Alias for host."
    },
    "user": {
      "type": "string",
      "description": "DAS Gateway V3 login username. Prefer secret.username for new instances."
    },
    "username": {
      "type": "string",
      "description": "Alias for user. Prefer secret.username for new instances."
    },
    "timeoutMs": {
      "type": "integer",
      "minimum": 1,
      "default": 2000,
      "description": "HTTP timeout in milliseconds."
    },
    "timeout_ms": {
      "type": "integer",
      "minimum": 1,
      "description": "Legacy alias for timeoutMs."
    }
  }
}
