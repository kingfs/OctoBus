{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "target": {
      "type": "string",
      "description": "Default SafeLine upstream gRPC target address, for example 10.9.33.133:50053."
    },
    "upstreamTarget": {
      "type": "string",
      "description": "Legacy alias for target."
    },
    "upstream_target": {
      "type": "string",
      "description": "Legacy alias for target."
    },
    "method": {
      "type": "string",
      "description": "Default upstream gRPC full method."
    },
    "upstreamMethod": {
      "type": "string",
      "description": "Legacy alias for method."
    },
    "upstream_method": {
      "type": "string",
      "description": "Legacy alias for method."
    },
    "timeoutMs": {
      "type": "integer",
      "minimum": 1,
      "default": 1500,
      "description": "Upstream gRPC timeout in milliseconds."
    },
    "timeout_ms": {
      "type": "integer",
      "minimum": 1,
      "description": "Legacy alias for timeoutMs."
    }
  }
}
