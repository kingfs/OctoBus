{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "apiToken": {
      "type": "string",
      "description": "Default SafeLine API token. Request api_token/apiToken still takes precedence when provided."
    },
    "api_token": {
      "type": "string",
      "description": "Legacy alias for apiToken."
    }
  }
}
